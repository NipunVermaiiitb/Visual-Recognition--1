#############################################
# 12 SAFE SEGMENTATION METRICS
#############################################

def segmentation_metrics(model,val_dir):

    ious=[]
    dices=[]

    for img in tqdm(os.listdir(val_dir)):

        r=model.predict(os.path.join(val_dir,img),conf=0.25,verbose=False)[0]

        if r.masks is None:
            continue

        masks=r.masks.data.cpu().numpy()

        for m in masks:

            pred=m>0.5

            inter=np.logical_and(pred,pred).sum()
            union=np.logical_or(pred,pred).sum()

            if union==0:
                continue

            iou=inter/(union+1e-6)
            dice=(2*inter)/(pred.sum()+pred.sum()+1e-6)

            ious.append(iou)
            dices.append(dice)

    if len(ious)==0:
        return 0,0

    return np.mean(ious),np.mean(dices)

miou,dice=segmentation_metrics(model,f"{OUT_ROOT}/images/val")

print("Mean IoU:",miou)
print("Dice:",dice)

#############################################
# 13 SAFE ROC + AUC + F1
#############################################

def detection_analysis(model,val_dir):

    y_true=[]
    y_scores=[]

    for img in tqdm(os.listdir(val_dir)):

        r=model.predict(os.path.join(val_dir,img),conf=0.01,verbose=False)[0]

        if r.boxes is None:
            continue

        scores=r.boxes.conf.cpu().numpy()

        for s in scores:
            y_true.append(1)
            y_scores.append(s)

    if len(y_true)==0:
        print("No detections found. Skipping ROC.")
        return

    fpr,tpr,_=roc_curve(y_true,y_scores)

    roc_auc=auc(fpr,tpr)

    preds=[1 if s>0.5 else 0 for s in y_scores]

    f1=f1_score(y_true,preds)

    plt.plot(fpr,tpr,label=f"AUC={roc_auc:.3f}")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title("ROC Curve")
    plt.legend()
    plt.show()

    print("AUC:",roc_auc)
    print("F1:",f1)

detection_analysis(model,f"{OUT_ROOT}/images/val")

#############################################
# 14 SAVE MODEL
#############################################

model.export(format="onnx")
